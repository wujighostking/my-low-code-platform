{
  "name": "my-low-code-platform",
  "type": "module",
  "version": "1.0.0",
  "private": "true",
  "packageManager": "pnpm@10.30.3",
  "description": "",
  "author": "",
  "license": "ISC",
  "keywords": [],
  "main": "index.js",
  "scripts": {
    "commitlint": "commitlint --edit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "turbo run test",
    "test:run": "turbo run test:run",
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "preview": "turbo run preview --filter=main",
    "dev": "turbo run dev --filter=main",
    "dev:nest": "turbo run dev --filter=nest",
    "dev:all": "turbo run dev"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "antd": "^6.3.1",
    "axios": "^1.13.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@unocss/eslint-plugin": "^66.6.6",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "lint-staged": "^16.3.2",
    "playwright": "^1.58.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3",
    "unocss": "^66.6.6",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "pnpm commitlint"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ]
  }
}
