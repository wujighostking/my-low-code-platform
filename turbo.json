{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!dist/**",
        "!.turbo/**",
        "!node_modules/.vite/**"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "test:run": {
      "dependsOn": [
        "^build"
      ],
      "cache": false
    },
    "test": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "dependsOn": [
        "build"
      ],
      "persistent": true
    }
  }
}
